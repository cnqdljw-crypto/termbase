<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/schemas/office/2018/08/extensions"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskpaneApp">
  
  <Id>TermBase-Word-Addin-2024</Id>
  <Version>1.0.0</Version>
  <ProviderName>TermBase</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="TermBase 术语助手"/>
  <Description DefaultValue="中↔西班牙语 术语识别与翻译助手 - 自动高亮文档中的专业术语"/>
  
  <Requirements>
    <Sets>
      <Set Name="WordApi" MinVersion="1.3"/>
    </Sets>
  </Requirements>
  
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  
  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR-USERNAME.github.io/termbase/termbase-office/index.html"/>
  </DefaultSettings>
  
  <Permissions>ReadWriteDocument</Permissions>
  
  <IconUrl DefaultValue="https://YOUR-USERNAME.github.io/termbase/termbase-office/icon.png"/>
  
</OfficeApp>
